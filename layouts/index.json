{{- $list := slice -}}
{{- range (where .Site.Pages "Kind" "in" (slice "page" "section")) -}}
  {{- if .Content -}}
  {{- $list = $list | append (dict
      "title" .Title
      "url" .RelPermalink
      "section" .Section
      "tags" (or .Params.tags slice)
      "settings" (or .Params.settings slice)
      "date" (cond .Date.IsZero "" (.Date.Format "2 January 2006"))
      "summary" (.Summary | plainify | truncate 180)
      "content" (.Plain | replaceRE "\\s+" " ")
  ) -}}
  {{- end -}}
{{- end -}}
{{- $list | jsonify -}}
